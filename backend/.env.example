# Servidor
PORT=3000
NODE_ENV=development

# En local puedes dejar estas URLs.
# En Railway, si frontend y backend están en el mismo servicio, puedes dejarlo vacío.
FRONTEND_URL=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# MySQL local
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=automundo

# Railway MySQL también es compatible con estas variables automáticas:
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, MYSQL_URL

# Seguridad
JWT_SECRET=CAMBIA_ESTE_SECRETO_LARGO_EN_PRODUCCION
JWT_EXPIRES_IN=8h
TURNSTILE_SECRET_KEY=